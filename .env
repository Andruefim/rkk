# Модель, частоты циклов, явные включения фич. Остальное — дефолты в backend (grep RKK_).

# --- ИИ ---
# RKK_OLLAMA_MODEL=gemma4:26b
RKK_OLLAMA_MODEL=gemma4:26b
RKK_OLLAMA_THINK=0

# --- Частоты (Гц; 0 = синхронно с тиком / выкл. фон) ---
RKK_AGENT_LOOP_HZ=15
RKK_L3_LOOP_HZ=4
RKK_CPG_LOOP_HZ=60
RKK_PHYSICS_BG_HZ=120
RKK_STEPS_PER_DO=12
RKK_CONCEPT_INJECT_EVERY=60
RKK_L4_WORKER=1

# --- Фичи ---
# RKK_LLM_LOOP=1
# disable to save memory
RKK_GNN_COMPILE=0
RKK_LOCOMOTION_CPG=1
# In-place CPG на ногах пока pelvis закреплён (intent_stride → физика ног).
RKK_CPG_DURING_FIXED_ROOT=1

# WM train: при активном CPG снижать l_int / lr пока locomotion.reward_ema < порога
RKK_WM_LOCO_GATING=1
RKK_WM_LOCO_REWARD_EMA_MIN=0.45
RKK_WM_LOCO_TRAIN_SCALE_FLOOR=0.25
RKK_WM_LOCO_INT_FLOOR=0.08
RKK_WM_L_INT_LOCO_MULT=0.15
# RKK_CEREBELLUM=1           # forward+inverse модели состояния↔команды ног; после MIN_TRAIN_STEPS заменяет ноги CPG (см. engine/cerebellum.py)
# RKK_REFLEX_STABILIZER=1   # быстрый корректор целей ног в CPG-потоке; обучение в agent-тике (см. engine/reflex_stabilizer.py)
RKK_CAUSAL_MOTOR_EXECUTOR=1   # intent_* × W_masked → суставы (без хардкода программ); см. engine/causal_motor_executor.py
RKK_CAUSAL_BLEND_CPG=0.65     # вес CPG при смешивании с каузальным исполнителем (если нет legacy MLP программ)
RKK_CAUSAL_EXECUTOR_MIN_ALPHA=0.25   # ниже — исполнитель не двигает суставы (только CPG)
RKK_INTERVENTION_BOOTSTRAP_TICKS=500  # сколько первых do(): intent_* кандидатам expected_ig ≥ 0.88
RKK_HOMEOSTATIC_IG=1                  # сигнал обучения System1: |Δ| по posture/com/foot, не d узлов
RKK_IG_FALLEN_POSTURE_TH=0.25        # ниже — считаем упавшим; IG по суставам (cold-start deadlock)
RKK_IG_FALLEN_GAIN=3.0               # усиление PE по суставам когда упал
RKK_IG_DIAG=1                        # [IGDiag] каждые 50 интервенций
# RKK_MOTOR_CORTEX_LEGACY_SPECS=1   # старые walk/balance/reach MLP в motor_cortex (иначе только GNN+CPG)
# RKK_SKILL_LIBRARY=1
RKK_SKILL_LIBRARY_PROB=0.75
RKK_RSI_FULL=0
# При RKK_RSI_FULL=1: не продлевать VL-relax чаще чем раз в N тиков (было «каждый тик»).
# RKK_RSI_FULL_VL_EXTEND_COOLDOWN=500
# Async scoring races WM/graph on another thread → crashes on Windows; keep 0 locally.
RKK_SCORE_ASYNC=0

# Tier 1: максимум значимых пар |W|≥thresh из матрицы за тик (без полного graph.edges). Дефолт 2048.
RKK_TIER1_EDGE_CAP=2048
# Snapshot для WS: число рёбер в JSON (не строить 10k+ Edge). Дефолт 512; 0 = только edge_count.
RKK_SNAPSHOT_EDGES_MAX=256

RKK_NOTEAR_EVERY=48
# 1 = пересчёт score_interventions каждый engine-тик; N>1 = реже (кеш на N тиков).
# Post-sleep SI ≈ 1100ms/tick; caching every 4 ticks cuts amortized cost to ~275ms.
# Windows: дефолт 12 если не задано; stale-кеш до 8× интервала (RKK_SCORE_STALE_*).
RKK_SCORE_CACHE_EVERY=20
RKK_SCORE_STALE_MULT=8
RKK_SCORE_STALE_ONLY=1
# RKK_SCORE_BG_REFRESH=1 — фоновый score (гонка с train_step; только если stale_only мало)

# Лимит кандидатов после edge-first (Tier1+2+3); сортировка по uncertainty. 0 = без капа. Дефолт 512.
RKK_SCORE_MAX_CANDIDATES=128
# Если discovery застрял — шум к expected_ig (перемешивание ранжирования).
RKK_SCORE_STUCK_DR_MAX=0.02
RKK_SCORE_STUCK_MIN_INTERVENTIONS=800
RKK_SCORE_STUCK_NOISE=0.3
# Случайных frontier-пар (Tier 3) в edge-first score_interventions; 0 = только рёбра + motor×objectives.
RKK_FRONTIER_SAMPLE=64

RKK_VISION_ASYNC_ENCODE=1
# Реже полный encode+cortex после intervene — меньше пиков inner_ms на секунды (hybrid/visual).
RKK_VISION_ENCODE_EVERY=48
RKK_PHASE_M_EVERY=8
RKK_CONCEPT_REFRESH_EVERY=8
# REM replay: не более ~80ms тяжёлой работы за engine-тик (избегаем 10–20s spike на tick 0 сна)
RKK_SLEEP_REM_BUDGET_MS=80
# После REM: grounded consolidate и gc.collect() дают multi-second stall — по умолчанию выкл.
RKK_SLEEP_GROUNDED=0
RKK_SLEEP_REM_GC=0

# RKK_MEMORY_RESUME_ON_START=1

# Phase K: Sleep consolidation + autosave.meta.json (рядом с RKK_MEMORY_PATH)
RKK_SLEEP_ENABLED=1
RKK_SLEEP_EVERY_TICKS=2000
RKK_SLEEP_FALL_THRESHOLD=50
RKK_SLEEP_DURATION_TICKS=10
# 10x LR during REM over-densified W, causing 60x score_interventions slowdown.
# 3x is enough for consolidation without saturating weight matrix.
RKK_SLEEP_REM_LR_MULT=3.0
# После пробуждения: окно тиков с увеличенным минимумом RKK_SCORE_CACHE_EVERY (agent.py).
RKK_POST_SLEEP_SCORE_RELAX_TICKS=720
RKK_POST_SLEEP_SCORE_CACHE_EVERY_FLOOR=40
# fixed_root: сдвиг top-1 кандидата если совпадает с последним do (agent.py).
RKK_FIXED_ROOT_SCORE_ROTATE_TICKS=20
# Aggressive pruning to keep graph sparse after sleep replay.
RKK_SLEEP_PRUNE_THRESHOLD=0.12
# REM: MoCap-клипы в PyBullet + inverse по intent_* (дорого). 0 = только replay падений + WM train в REM.
RKK_SLEEP_MOCAP_DREAMS=0

# --- Humanoid motor smoothness / authority ---
# Чуть выше базовая сила + recovery (ниже) помогают встать после падения / упор руками.
RKK_HUMANOID_MOTOR_TORQUE_SCALE=1.22
RKK_HUMANOID_JOINT_SMOOTH_ALPHA=0.28
RKK_HUMANOID_JOINT_MAX_STEP=0.10
RKK_HUMANOID_CTRL_VEL_MIN=0.40
RKK_HUMANOID_CTRL_VEL_MAX=1.00
RKK_HUMANOID_CTRL_FORCE_MIN=0.58
RKK_HUMANOID_CTRL_FORCE_MAX=1.00
# Recovery: низкий com_z и/или стопы «в воздухе» → сильнее PD и сильнее intent→spine/плечи (pybullet_humanoid + environment).
RKK_RECOVERY_MOTOR_ENABLE=1
RKK_RECOVERY_MOTOR_BOOST=1.30
RKK_RECOVERY_INTENT_MAP_ENABLE=1
RKK_RECOVERY_COM_Z_BELOW=0.56
RKK_RECOVERY_FOOT_Z_BELOW=0.12
RKK_RECOVERY_SPINE_GAIN_MAX=1.55
RKK_RECOVERY_ARM_GAIN_MAX=1.38
# Постуральный nudge к spine_pitch в recovery (environment._balance_spine_pitch_nudge).
RKK_RECOVERY_BALANCE_REFLEX_MULT=1.32
# Мяч песочницы под тазом на низком CoM: сдвинуть в сторону (pybullet_humanoid._maybe_unstick_ball_from_torso).
RKK_BALL_UNSTUCK_ENABLE=1
RKK_BALL_UNSTUCK_COM_Z_BELOW=0.62
RKK_BALL_UNSTUCK_HORIZ_PAD=0.42
RKK_BALL_UNSTUCK_PUSH=0.62

# --- GNN / WM ---
RKK_WM_PASSIVE_MIX=0.5
# Регуляризация и отображение рёбер: |W_ij|≥RKK_EDGE_THRESH считается ребром (UI, score, edge_count).
# Bootstrap: мягче L1 и ниже порог рёбер, пока граф разгоняется (см. также RKK_INTERVENTION_BOOTSTRAP_TICKS).
RKK_LAMBDA_L1=0.003
RKK_EDGE_THRESH=0.05
# Префиксы узлов: целые строки/столбцы W не обрезаются по порогу сна. Не задано = concept_,proprio_,mc_,intent_.
# Для агрессивной обрезки при раздутом графе: RKK_PRUNE_PROTECT_PREFIXES= (пустое значение — только frozen рёбра).
# RKK_PRUNE_PROTECT_PREFIXES=concept_,proprio_,mc_,intent_

# --- LeWM: Parallel Sequence Training + SIGReg Anti-Collapse ---
RKK_WM_SEQ_LEN=3
RKK_WM_SEQ_BATCH=1
RKK_WM_INT_SAMPLES=2
RKK_WM_SEQ_MULTISCALE=0
RKK_WM_SIGREG_LAMBDA=0.1
RKK_WM_SIGREG_PROJ=256

# --- CEM Planner: Model-Based Action Selection via World Model ---
RKK_CEM_PLANNING=1
RKK_CEM_EVERY=4
RKK_CEM_SAMPLES=32
RKK_CEM_ITERS=3
RKK_CEM_ROLLOUT=1

# --- Value Layer / imagination (базовая стоимость тика) ---
RKK_IMAGINATION_STEPS=1
RKK_VL_FALLBACK_TRIES=3
# При fixed_root: Value Layer без WM для intent_* (дешёвая подстановка в узлы) — см. agent.py / value_layer.py
RKK_VL_FAST_FIXED_ROOT=1
RKK_GOAL_PLAN_MIN_WM_STEPS=40
RKK_PLAN_MAX_BRANCH_FIXED=16

# --- Value Layer (ранняя ходьба) ---
RKK_LOCO_VL_WARMUP_TICKS=0
RKK_LOCO_VL_WARMUP_BLEND=0

# --- Humanoid curriculum ---
# Фаза 1: торс закреплён — без падения, GNN учит intent→joint; затем снятие pelvis.
RKK_AUTO_FIXED_ROOT_TICKS=800
# Release: mastery + posture streak + support_bias swing (не только mq).
RKK_FIXED_ROOT_RELEASE_MASTERY=0.72
RKK_FIXED_ROOT_RELEASE_MIN_TICKS=400
RKK_FR_RELEASE_POSTURE_MIN=0.85
RKK_FR_RELEASE_POSTURE_STREAK=40
RKK_FR_RELEASE_BIAS_RANGE=0.15
RKK_FR_RELEASE_BIAS_WINDOW=30
RKK_POST_FR_STABILIZE_TICKS=120
RKK_POST_FR_REATTACH_TICKS=150
RKK_POST_FR_REATTACH_MAX=3
RKK_FR_REATTACH_POSTURE_MIN=0.82
RKK_PHYS_CURRICULUM_INJECT_EVERY=50
# Сколько первых тиков повторять enable_fixed_root, если обёртка env раньше мешала (humanoid под Visual).
# RKK_CURRICULUM_FIXED_ROOT_RETRY_MAX=16
RKK_CURRICULUM_WALK_MIN_TICK=2000

RKK_PHASE3_HTTP_TIMEOUT=500

RKK_MOTOR_CORTEX=1
RKK_CPG_ANNEAL_THRESHOLD=0.58   # качество EMA для старта annealing
RKK_CPG_ANNEAL_RATE=5e-5        # скорость fade-out CPG
RKK_CPG_MIN_WEIGHT=0.08         # минимум CPG (остаётся scaffold)
RKK_MC_RSI_MIN_TICKS=1500       # тиков до первого spawn программы

# Level 1-A: Embodied LLM Reward Shaping
RKK_LLM_MOTOR_REWARD=1
RKK_LLM_MOTOR_REWARD_EVERY=300
RKK_LLM_MOTOR_REWARD_WEIGHT=0.6
RKK_LLM_MOTOR_TIMEOUT=45
RKK_LLM_MOTOR_SEEDS=1
RKK_LLM_MOTOR_FALLBACK=1

# Level 1-B: Visual Body Grounding
RKK_VISUAL_GROUNDING=1
RKK_GROUNDING_EVERY=30
RKK_GROUNDING_DIST_THRESH=0.22
RKK_GROUNDING_MIN_SCORE=0.25
RKK_GROUNDING_EDGE_W=0.35
RKK_GROUNDING_CONFIRM_N=8

# Level 1-C: Slot Reconstruction Decoder
RKK_VISION_RECON_ENABLED=1
RKK_VISION_RECON_WEIGHT=0.3


# Level 2-D: Episodic Fall Memory
RKK_EPISODE_MEMORY=1
RKK_EPISODE_FALL_MAXLEN=50
RKK_EPISODE_SUCCESS_MAXLEN=30
RKK_EPISODE_PRETRIGGER=8
RKK_EPISODE_PATTERN_MIN=3

# Level 2-E: LLM Curriculum Generator
RKK_LLM_CURRICULUM=1
RKK_LLM_CURRICULUM_EVERY=800
RKK_LLM_CURRICULUM_TIMEOUT=60
RKK_LLM_CURRICULUM_MAX_STAGES=12

# Level 2-F: RSSM Temporal World Model (off by default — enable after tick ~2000)
RKK_WM_RSSM=0
RKK_WM_RSSM_HIDDEN=64
# После upgrade: шаги imagination в value check (меньше = быстрее, когда RSSM включён).
RKK_WM_RSSM_IMAGINATION=6
RKK_WM_RSSM_TBPTT=8
RKK_WM_RSSM_LR=3e-4
RKK_WM_RSSM_UPGRADE_TICK=0
# Реже RSSM maybe_train() в тике (push каждый тик, train реже).
RKK_RSSM_TRAIN_EVERY=16

# Level 3-G: Proprioception Stream
RKK_PROPRIO_ENABLED=1
RKK_PROPRIO_EVERY=3
RKK_PROPRIO_HIDDEN=24
RKK_EMPOWERMENT_K=4
RKK_EMPOWERMENT_SAMPLES=8

# Level 3-H: Unified Reward Coordinator
RKK_REWARD_ENABLED=1
RKK_REWARD_EFFICIENCY_SCALE=0.15
RKK_REWARD_EMPOWERMENT_SCALE=0.20
RKK_REWARD_CURIOSITY_SCALE=0.15
RKK_REWARD_TASK_SCALE=0.50
RKK_REWARD_SURVIVAL_ANOMALY=0.75
RKK_REWARD_CONSTITUTION_EVERY=200
RKK_REWARD_CURIOSITY_EMA=0.95

# Level 3-I: Multi-scale Time
RKK_TIMESCALE_ENABLED=1
RKK_TIMESCALE_T0=3
RKK_TIMESCALE_T1=30
RKK_TIMESCALE_T2=300
RKK_TIMESCALE_T3=3600

# Phase J: Inner Voice
RKK_INNER_VOICE_ENABLED=1
RKK_INNER_VOICE_HIDDEN=128
RKK_INNER_VOICE_CONCEPTS=5
RKK_INNER_VOICE_EVERY=300

# Phase J: LLM Teacher (τ3 offline)
RKK_LLM_TEACHER_ENABLED=1
RKK_LLM_TEACHER_EVERY_SEC=320
RKK_LLM_TEACHER_GUIDE_EVERY=3
RKK_LLM_TEACHER_LESSON_EVERY=10
RKK_LLM_TEACHER_TIMEOUT=300

# .env
RKK_SPEECH_ENABLED=1
RKK_SPEECH_LANG=ru

# Phase M: Visual Grounding (VLM slots → SlotLabeler → VisualInnerVoice)
RKK_VISUAL_VOICE_ENABLED=1
RKK_SLOT_LABEL_ENABLED=1
# RKK_SLOT_LABEL_EVERY=30
# RKK_VISUAL_INJECT_TOP=5

RKK_WORLD_BRIDGE_LABEL_EVERY=2


# diagnostics (trace/compare_to после сна даёт многосекундные паузы — держим выкл.)
RKK_MEMORY_DIAG=1
RKK_MEMORY_TRACE=0
RKK_MEMORY_TRACE_SLEEP=0
RKK_MEMORY_DIAG_INTERVAL=4000

# Per-tick JSONL run log for LLM post-mortem (truncated each start). Path relative to repo root.
RKK_TICK_RUN_LOG=1
RKK_TICK_RUN_LOG_PATH=logs/rkk_run.jsonl
RKK_TICK_RUN_LOG_EVERY=1
RKK_TICK_RUN_LOG_PHYS=1
RKK_TICK_RUN_LOG_EVENTS=1

# full agi autonomy
RKK_BOOTSTRAP_ONLY=1 
RKK_DEVICE=cuda
RKK_SKIP_AUTO_HUMANOID_LLM=0
RKK_SKIP_AUTO_VISION=0
RKK_SKIP_PHASE3_LLM=1
RKK_LLM_LOOP=0
RKK_MEMORY_RESUME_ON_START=1
RKK_SKILL_LIBRARY=0
# RKK_AUTO_FIXED_ROOT_TICKS задаётся в секции «Humanoid curriculum» выше (дубликат здесь перезаписывал и отключал фазу 1).

RKK_HYPOTHESIS_EIG=0
RKK_CEM_PLANNING=0
# Дорого: материализация всех рёбер; wake — только с RKK_EDGE_DUP_DIAG_WAKE=1 в коде.
RKK_EDGE_DUP_DIAG=0
RKK_EDGE_DUP_DIAG_WAKE=0
RKK_W_DIAG=0
RKK_AGENT_LOOP_TRACEBACK=0

# --- Phase T: Trajectory Contrastive Learning ---
# Обучение GNN на уровне эпизодов (50 тиков), а не одиночных переходов.
# Даёт temporal credit assignment: GNN учится предсказывать качество ПАТТЕРНОВ, не шагов.
RKK_TRAJECTORY_ENABLED=1
# Считать trajectory contrastive loss только каждый N-й WM train_step (дешевле CPU/GPU).
RKK_TRAJECTORY_EVERY=3
RKK_TRAJECTORY_SEGMENT_LEN=50
RKK_TRAJECTORY_OVERLAP=10
RKK_TRAJECTORY_BUFFER_SIZE=200
RKK_TRAJECTORY_LOSS_WEIGHT=0.25
RKK_TRAJECTORY_TRAIN_MIN_SEGS=6

# --- Phase T: Progressive Variable Scope ---
# Ограничивает DO-переменные по фазам: intent_* → ноги/спина → руки/голова → слоты.
# Наблюдения видны всегда; ограничение только на интервенции.
# Снижает эффективную размерность с 143D до ~8D в начале.
RKK_PROGRESSIVE_SCOPE=1
RKK_SCOPE_MASTERY_WINDOW=80
RKK_SCOPE_MASTERY_THRESHOLD=0.55
RKK_SCOPE_MIN_TICKS_PER_PHASE=300

RKK_FALL_RECOVERY_TICKS=200
RKK_FALL_RECOVERY_STALL_TICKS=100

VITE_RKK_GRAPHICS_QUALITY=low

# --- Strong AI architecture gap plan (defaults conservative; enable per phase) ---
# RKK_PEARL_API=1
# Если PEARL включён: push в RollingObservationPosterior реже (дорого при большом d).
RKK_PEARL_PUSH_EVERY=8
# RKK_PRECISION_GROUPS=0
# RKK_PRECISION_CALIB_WINDOW=50
# RKK_VALUE_VETO=0
# RKK_REM_WM_TRAIN=0
# RKK_SZ_SPLIT=0
# RKK_TEMPORAL_PRECISION_ROUTING=0
# RKK_PEARL_Z_ENCODER=0
# RKK_FE_DECOMP=0
# RKK_EFFERENCE_CORR_PROPRIO=0.9
# RKK_EFFERENCE_CORR_VISION=0.7