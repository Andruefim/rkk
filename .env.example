# ── Модель (нет дефолта) ────────────────────────────────────────────
RKK_OLLAMA_MODEL=gemma4:26b
RKK_OLLAMA_THINK=0

# ── Железо/перф (site-specific) ─────────────────────────────────────
RKK_AGENT_LOOP_HZ=15
RKK_L3_LOOP_HZ=4
RKK_STEPS_PER_DO=20

# ── Критические override дефолтов ───────────────────────────────────
# Дефолт 0 (выключен до 2000 тиков) — мы запускаем сразу
RKK_WM_RSSM=1

# Дефолт 0 — нужен для Phase K persistence
RKK_MEMORY_RESUME_ON_START=1

# ── Phase K: LLM Teacher ─────────────────────────────────────────────
# Нужен между снами (ANNOTATE/GUIDE → дистилляция InnerVoiceNet)
# LESSON запускается только из SleepController, не из teacher напрямую
RKK_LLM_TEACHER_ENABLED=1
RKK_LLM_TEACHER_EVERY_SEC=600
RKK_LLM_TEACHER_TIMEOUT=600