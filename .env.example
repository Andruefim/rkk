RKK_LLM_LOOP=1

# Ollama: одна модель для bootstrap, VLM, Phase3, LLM loop (по умолчанию gemma4:e4b)
RKK_OLLAMA_MODEL=qwen3.5:9b
# Qwen3: иначе весь num_predict уходит в поле thinking, response пустой — по умолчанию think=false в запросах
# RKK_OLLAMA_THINK=1
# RKK_OLLAMA_URL=http://localhost:11434/api/generate
# Короткий алиас имени, если RKK_OLLAMA_MODEL не задан: OLLAMA_MODEL=llama3.2

# format=json для Phase3/VLM (часто ломает Gemma → мета-JSON); по умолчанию выкл.
# RKK_OLLAMA_JSON_FORMAT_TEACHER_VLM=1
# Humanoid RAG edges: по умолчанию без format=json (иначе key/key_2/…); принудительно: RKK_OLLAMA_JSON_FORMAT_HUMANOID=1
# Общий переключатель format=json для bootstrap и LLM loop: RKK_OLLAMA_JSON_FORMAT=0
# VLM slot_lexicon: лимит токенов ответа Ollama (слишком мало обрезает JSON); по умолч. 1600
# RKK_VLM_NUM_PREDICT=1600
# Phase3 teacher: таймаут HTTP (сек), num_predict
# RKK_PHASE3_HTTP_TIMEOUT=300
# RKK_PHASE3_NUM_PREDICT=2400