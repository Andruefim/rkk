RKK_LLM_LOOP=1

# Ollama: одна модель для bootstrap, VLM, Phase3, LLM loop (по умолчанию gemma4:e4b)
RKK_OLLAMA_MODEL=qwen3.5:9b
# Qwen3: иначе весь num_predict уходит в поле thinking, response пустой — по умолчанию think=false в запросах
# RKK_OLLAMA_THINK=1
# RKK_OLLAMA_URL=http://localhost:11434/api/generate
# Короткий алиас имени, если RKK_OLLAMA_MODEL не задан: OLLAMA_MODEL=llama3.2

# format=json для Phase3/VLM (часто ломает Gemma → мета-JSON); по умолчанию выкл.
# RKK_OLLAMA_JSON_FORMAT_TEACHER_VLM=1
# Humanoid RAG edges: по умолчанию без format=json (иначе key/key_2/…); принудительно: RKK_OLLAMA_JSON_FORMAT_HUMANOID=1
# Общий переключатель format=json для bootstrap и LLM loop: RKK_OLLAMA_JSON_FORMAT=0
# VLM slot_lexicon: лимит токенов ответа Ollama (слишком мало обрезает JSON); по умолч. 1600
# RKK_VLM_NUM_PREDICT=1600
# Phase3 teacher: таймаут HTTP (сек), num_predict
# RKK_PHASE3_HTTP_TIMEOUT=300
# RKK_PHASE3_NUM_PREDICT=2400

# World model Neural ODE (torchdiffeq): dY/dτ = forward_dynamics(Y,a)−Y, τ∈[T0,T1]
# RKK_WM_NEURAL_ODE=1
# RKK_WM_ODE_TIME_POINTS=17
# RKK_WM_ODE_METHOD=dopri5
# RKK_WM_ODE_T0=0
# RKK_WM_ODE_T1=1

# Humanoid PyBullet: шагов симуляции после каждого do(); меньше — быстрее CPU
# RKK_STEPS_PER_DO=4
# Фоновый stepSimulation с фиксированной частотой (Гц); >0 отключает step() на главном потоке между do()
# RKK_PHYSICS_BG_HZ=120

# GNN: torch.compile на CUDA/MPS (PyTorch 2+)
# RKK_GNN_COMPILE=1

# Агент: не пересчитывать score_interventions каждый тик (1 = как раньше)
# RKK_SCORE_CACHE_EVERY=3
# По умолчанию синхронный EIG в главном потоке. RKK_SCORE_ASYNC=1 — фоновый daemon (экспериментально)
# RKK_SCORE_ASYNC=1

# Визуальная среда: encode+JPEG в фоне (очередь 1 кадр; GPU со второго потока)
# RKK_VISION_ASYNC_ENCODE=1

# Phase A locomotion: CPG ритм ног + суррогатный reward (com_z, com_x); только humanoid, не fixed_root
# RKK_LOCOMOTION_CPG=1
# Low-level CPG в отдельном потоке (Hz), иерархия L1 отдельно от GNN. 0 по умолч. = только после agent.step
# RKK_CPG_LOOP_HZ=60
# RKK_CPG_PHYS_SUBSTEPS=0   # 0 = max(1, steps_per_do//2)
# RKK_CPG_REWARD_WINDOW=16

# Phase B: L2 skill library (один кадр последовательности за тик; без count на n_interventions)
# RKK_SKILL_LIBRARY=1
# RKK_SKILL_LIBRARY_PROB=0.1
# RKK_SKILL_GOAL=walk   # подсказка при стойке: com_z низкий → цель stand (встать)

# Phase C: full RSI (NAS-lite GNN hidden↑, CPG perturb, skill curriculum, VL phi relax). Отдельно от rsi_lite.
# RKK_RSI_FULL=1
# RKK_RSI_FULL_MIN_SNAPSHOTS=200
# RKK_RSI_FULL_WINDOW=100
# RKK_RSI_FULL_COOLDOWN=320
# RKK_RSI_FULL_HIDDEN_MAX=128
# RKK_RSI_FULL_DR_EPS=0.0001
# RKK_RSI_FULL_LOCO_EPS=0.01
# RKK_RSI_FULL_PHI_DROP=0.035
# RKK_RSI_FULL_VL_RELAX=1
# RKK_RSI_FULL_VL_RELAX_FACTOR=0.9
# RKK_RSI_FULL_VL_RELAX_TICKS=400
# RKK_RSI_FULL_SKILL_MIN_USES=20
# RKK_RSI_FULL_SKILL_SR_EPS=0.012
# RKK_RSI_FULL_SKILL_SR_FLOOR=0.78
# RKK_RSI_FULL_CPG_PHASE_NOISE=0.3
# RKK_RSI_FULL_CPG_FREQ_NOISE=0.1
# RKK_RSI_FULL_SNAPSHOT_CAP=500